import fetch from 'node-fetch';
import fs from 'fs';

const BASE_URL = "https://dareloom.fun";
const INDEXNOW_KEY = "c5b6124b5f8744fbb1a44a96266b9aa7";

export async function notifyEngines(urls = []) {
    if (urls.length === 0) return;
    
    console.log(`📡 Sending ${urls.length} URLs to IndexNow...`);
    const endpoint = "https://api.indexnow.org/indexnow";
    const data = {
        host: "dareloom.fun",
        key: INDEXNOW_KEY,
        keyLocation: `${BASE_URL}/${INDEXNOW_KEY}.txt`,
        urlList: urls
    };

    try {
        const res = await fetch(endpoint, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data)
        });
        if (res.ok) console.log("✅ IndexNow Notification Sent!");
    } catch (e) {
        console.error("❌ IndexNow Failed:", e.message);
    }
}
